{
  "PT": {
    "slot_button": ".tls-time-unit, button[data-time]",
    "slot_available": ".tls-time-unit.available, .tls-time-unit:not(.-selected):not(:disabled)",
    "slot_selected": ".tls-time-unit.selected, .tls-time-unit.-selected",
    "month_tab": "a[href*='month=']",
    "day_cell": ".day-cell",
    "day_cell_available": ".day-cell.available",
    "csrf_input": "input[name='__RequestVerificationToken']",
    "no_slots_text": "We currently don't have any appointment slots available.",
    "book_button_text": "Book your appointment",
    "continue_button_text": "Continue"
  },
  "BE": {
    "slot_button": "a.time-slot, button.time-slot",
    "slot_available": "a.time-slot.available, button.time-slot:not([disabled])",
    "slot_selected": "a.time-slot.selected, button.time-slot.selected",
    "month_tab": "a.month-link, td.month-cell",
    "day_cell": "td.day-cell, a.day-link",
    "csrf_input": "input[name='__RequestVerificationToken'], input[name='token']",
    "no_slots_text": "Unfortunately, there are no appointments available at this time",
    "book_button_text": "Book",
    "continue_button_text": "Continue"
  }
